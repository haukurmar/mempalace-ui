{
	"name": "@memui/palace-clients",
	"version": "0.0.0",
	"private": true,
	"description": "Node-only clients for the local MemPalace v3.3.4+ — read-only better-sqlite3 access to chroma.sqlite3 and a stdio JSON-RPC client to mempalace-mcp.",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./sqlite-client": {
			"types": "./src/sqlite-client/index.ts",
			"default": "./src/sqlite-client/index.ts"
		},
		"./mcp-client": {
			"types": "./src/mcp-client/index.ts",
			"default": "./src/mcp-client/index.ts"
		},
		"./connect": {
			"types": "./src/connect.ts",
			"default": "./src/connect.ts"
		}
	},
	"files": [
		"src"
	],
	"scripts": {
		"check-types": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@memui/palace-types": "workspace:*",
		"@modelcontextprotocol/sdk": "catalog:",
		"better-sqlite3": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@memui/biome-config": "workspace:*",
		"@memui/typescript-config": "workspace:*",
		"@types/better-sqlite3": "catalog:",
		"@types/node": "25.6.0"
	}
}
