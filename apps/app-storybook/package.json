{
	"name": "app-storybook",
	"version": "0.0.0",
	"private": true,
	"description": "Storybook app for the @memui/ui design system",
	"type": "module",
	"scripts": {
		"dev": "storybook dev -p 6006",
		"build": "storybook build",
		"check-types": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"test-storybook": "test-storybook"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@memui/biome-config": "workspace:*",
		"@memui/design-tokens": "workspace:*",
		"@memui/typescript-config": "workspace:*",
		"@memui/ui": "workspace:*",
		"@storybook/react-vite": "10.3.6",
		"@storybook/test-runner": "0.24.3",
		"@tailwindcss/vite": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"playwright": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:",
		"storybook": "10.3.6",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:"
	}
}
