{
	"name": "@memui/ui",
	"version": "0.0.0",
	"private": true,
	"description": "mempalace-ui design system: primitives, composed components, patterns",
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./primitives": {
			"types": "./src/primitives/index.ts",
			"default": "./src/primitives/index.ts"
		},
		"./components": {
			"types": "./src/components/index.ts",
			"default": "./src/components/index.ts"
		},
		"./patterns": {
			"types": "./src/patterns/index.ts",
			"default": "./src/patterns/index.ts"
		},
		"./lib/utils": {
			"types": "./src/lib/utils.ts",
			"default": "./src/lib/utils.ts"
		}
	},
	"files": [
		"src"
	],
	"scripts": {
		"check-types": "tsc --noEmit",
		"lint": "biome lint .",
		"format": "biome format --write ."
	},
	"dependencies": {
		"class-variance-authority": "catalog:",
		"clsx": "catalog:",
		"cmdk": "^1.1.1",
		"lucide-react": "catalog:",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"sonner": "^2.0.7",
		"tailwind-merge": "catalog:"
	},
	"peerDependencies": {
		"react": "catalog:",
		"react-dom": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "catalog:",
		"@memui/biome-config": "workspace:*",
		"@memui/design-tokens": "workspace:*",
		"@memui/typescript-config": "workspace:*",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"react": "catalog:",
		"react-dom": "catalog:"
	}
}
